PORT=5000
NODE_ENV=development
# Frontend URL(s) allowed via CORS — comma-separate multiple. Leave blank in dev.
CORS_ORIGIN=http://localhost:3000

NEWS_API_KEY=

# LLM — Groq (OpenAI-compatible) — Primary provider
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEYS=
GROQ_BASE_URL=
LLM_MODEL=openai/gpt-oss-20b

# LLM — Google Gemini — Fallback provider (auto-failover when Groq quota runs out)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.0-flash

# Markets — Massive API (Polygon wrapper)
MASSIVE_API_KEY=

# News sources
GUARDIAN_API_KEY=

MAX_EVENTS=100
LLM_TIMEOUT=300000
LLM_BATCH_SIZE=2
MAX_ARTICLES_PER_RUN=120
MAX_LLM_CALLS_PER_RUN=30
LLM_CONFIDENCE_THRESHOLD=0.4
LLM_QUOTA_COOLDOWN_MS=60000
RSS_PER_FEED_LIMIT=25

PIPELINE_INTERVAL_MINUTES=15
PIPELINE_ENABLED=true
SKIP_INITIAL_PIPELINE=false

# ── Rate Limiting (requests per minute per IP) ──────────────────
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_EVENTS=60
RATE_LIMIT_DATES=120
# Proxy hops to trust for real IP detection (1 = nginx/cloud LB in front)
TRUST_PROXY_HOPS=1

# ── Cluster / Load Balancing ────────────────────────────────────
# Number of worker processes (default = number of CPU cores)
CLUSTER_WORKERS=2


MONGODB_URI=
MONGODB_DB_NAME=world_monitor
MONGO_RETRY_COOLDOWN_MS=60000
RETENTION_DAYS=15
CHAT_ROOM_INACTIVE_MINUTES=10

REDIS_HOST=
REDIS_PORT=
REDIS_URL=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_CACHE_TTL_SECONDS=1296000
REDIS_MAX_ARCHIVE_DATES=45
REDIS_MAX_MEMORY_MB=30
REDIS_EVICTION_THRESHOLD_PCT=85

# LangCache — Redis semantic LLM response cache
# Avoids calling Groq when same/similar prompt was already answered
# Get your endpoint from: Redis Cloud Dashboard → LangCache → API Endpoint
LANGCACHE_BASE_URL=
LANGCACHE_API_KEY=
LANGCACHE_ID=
LANGCACHE_SIMILARITY_THRESHOLD=0.95
