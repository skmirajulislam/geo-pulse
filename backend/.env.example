PORT=5000
NODE_ENV=development
# Frontend URL(s) allowed via CORS — comma-separate multiple. Leave blank in dev.
CORS_ORIGIN=http://localhost:3000

NEWS_API_KEY=6b0381d905bf48519c96fd2ccee7a4c2

# LLM — Groq (OpenAI-compatible) — Primary provider
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEYS=
GROQ_BASE_URL=
LLM_MODEL=openai/gpt-oss-20b

# LLM — Google Gemini — Fallback provider (auto-failover when Groq quota runs out)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.0-flash

# Markets — Massive API (Polygon wrapper)
MASSIVE_API_KEY=3E_ChYscBI3bdbNLC9L770KtELG44wFD

# News sources
GUARDIAN_API_KEY=

MAX_EVENTS=100
LLM_TIMEOUT=300000
LLM_BATCH_SIZE=2
MAX_ARTICLES_PER_RUN=120
MAX_LLM_CALLS_PER_RUN=30
LLM_CONFIDENCE_THRESHOLD=0.4
LLM_QUOTA_COOLDOWN_MS=60000
RSS_PER_FEED_LIMIT=25

PIPELINE_INTERVAL_MINUTES=15
PIPELINE_ENABLED=true
SKIP_INITIAL_PIPELINE=false

# ── Rate Limiting (requests per minute per IP) ──────────────────
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_EVENTS=60
RATE_LIMIT_DATES=120
# Proxy hops to trust for real IP detection (1 = nginx/cloud LB in front)
TRUST_PROXY_HOPS=1

# ── Cluster / Load Balancing ────────────────────────────────────
# Number of worker processes (default = number of CPU cores)
CLUSTER_WORKERS=2


